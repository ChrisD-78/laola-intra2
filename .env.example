# Neon Database Connection
DATABASE_URL=your-neon-connection-string-here

# Stack Auth - Authentication
NEXT_PUBLIC_STACK_PROJECT_ID=your-stack-project-id
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=your-stack-publishable-key
STACK_SECRET_SERVER_KEY=your-stack-secret-key

# --- KI-Agent (Route /agent, nur Admins) – Anthropic Messages API ---
# Key aus https://console.anthropic.com/ → API Keys (nie committen, nur .env.local / Netlify).
# Nach Änderung: lokal Dev-Server neu starten; auf Netlify: Variable speichern + Redeploy.
ANTHROPIC_API_KEY=
# Optional: Modell überschreiben (Standard siehe src/app/api/agent/message/route.ts)
# AGENT_ANTHROPIC_MODEL=claude-sonnet-4-20250514

# Agent: IMAP-Eingang (Outlook → weiterleiten auf EMAIL_USER-Gmail), Sync per Cron
# Zufälliges Secret; Aufruf: POST oder GET /api/agent/inbox/sync mit Authorization: Bearer … oder ?token=
AGENT_INBOX_CRON_SECRET=
# Optional: eigene IMAP-Zugangsdaten statt EMAIL_USER / EMAIL_PASS
# AGENT_IMAP_USER=
# AGENT_IMAP_PASS=
# AGENT_IMAP_HOST=imap.gmail.com
# Optional: Signatur-Name in E-Mail-Antwortentwürfen
# AGENT_MAIL_SIGNER_NAME=Vorname Nachname
