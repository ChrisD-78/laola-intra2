# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Supabase Service Role Key (for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Configuration
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# KI-Agent (/agent, Admins) – gleiche Variablen auch in .env.local nutzen
# Anthropic Console: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=
# AGENT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# IMAP für Agent-Posteingang (Outlook→Gmail weiterleiten), Sync: /api/agent/inbox/sync
AGENT_INBOX_CRON_SECRET=

# Sauna Aufgussplan (Admin /agent/sauna) – nutzt dieselbe DATABASE_URL
# Tabelle anlegen: sql/create_sauna_aufguss_snapshot.sql (Neon SQL Editor)
