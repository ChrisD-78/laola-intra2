# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Optional: Supabase Service Role Key (for server-side operations)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Email Configuration (Formulare + Agent-Fallback für Protokoll/KI-Antworten)
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Optional: eigener SMTP für Agent (Protokoll per Mail, KI-Antworten) – sonst Gmail oben
# AGENT_SMTP_HOST=smtp.ionos.de
# AGENT_SMTP_PORT=465
# AGENT_SMTP_USER=
# AGENT_SMTP_PASSWORD=
# AGENT_SMTP_FROM_EMAIL=
# AGENT_SMTP_FROM_NAME=LA OLA KI-Assistent

# KI-Agent (/agent, Admins)
# Schlüssel: https://console.anthropic.com/settings/keys
# Produktion (Netlify): Site configuration → Environment variables → ANTHROPIC_API_KEY
# Lokal: .env.local mit gleichem Namen; nach Änderung in Netlify neu deployen
ANTHROPIC_API_KEY=
# Optional: Audio-Datei → Transkript für Protokoll-Generator (OpenAI Whisper)
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# AGENT_ANTHROPIC_MODEL=claude-sonnet-4-20250514
# IMAP für Agent-Posteingang (Outlook→Gmail weiterleiten), Sync: /api/agent/inbox/sync
AGENT_INBOX_CRON_SECRET=

# Sauna Aufgussplan (Admin /agent/sauna) – nutzt dieselbe DATABASE_URL
# Tabelle anlegen: sql/create_sauna_aufguss_snapshot.sql (Neon SQL Editor)
